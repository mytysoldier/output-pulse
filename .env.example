# GitHub API token. Issue #8で使用予定。
GH_READ_TOKEN=

# Local PostgreSQL connection strings. Issue #6以降で使用予定。
# compose.yamlの開発専用認証情報に対応する。本番の接続情報は設定しないこと。
DATABASE_URL=postgresql://output_pulse:output_pulse@localhost:5432/output_pulse
DATABASE_MIGRATION_URL=postgresql://output_pulse:output_pulse@localhost:5432/output_pulse

# Slack notification settings. Issue #13で使用予定。
SLACK_BOT_TOKEN=
SLACK_USER_ID=
