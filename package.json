{
  "name": "output-pulse",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub開発実績を収集して可視化する個人用ダッシュボード",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "format": "prettier --write \"{src,tests}/**/*.ts\" \"*.{json,mjs,ts}\"",
    "format:check": "prettier --check \"{src,tests}/**/*.ts\" \"*.{json,mjs,ts}\"",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "typescript": "6.0.0-beta",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
